# ==============================================================================
# DEFAULT POLICY: Ignore everything
# ==============================================================================
*

# ==============================================================================
# WHITELIST RULES: Allow specific directories and file extensions
# ==============================================================================

# Allow Git to look into the directory structure (required for whitelisting)
!*/
!**/

# Allow .gitignore file
!.gitignore

# Allow root files
!scripts/*
!srcs/**

# Whitelist specific file extensions everywhere
!*.hpp
!*.cpp
!*.cfg
!*.rpt

# Whitelist log files generally, but exclude specific IDE logs
!*.log
ide_verbose.log
ide.log
vitis.log
xcd.log
*.steps.log

# ==============================================================================
# ABSOLUTE BLACKLIST: Force ignore specific structures
# ==============================================================================

# Force ignore specific IDE/HLS directories
**/build/
**/.autopilot/
**/autowrap/
**/wrapc/
**/wrapc_pc/

# ==============================================================================
# VERILOG DIRECTORY EXCEPTIONS
# ==============================================================================

# 1. Force ignore ALL files inside 'verilog' (overrides global !*.rpt and !*.log)
**/verilog/**

# 2. Allow Git to traverse subdirectories inside 'verilog'
!**/verilog/**/

# 3. Whitelist only the simulation databases and waveform configurations
!**/verilog/**/*.wdb
!**/verilog/**/*.wcfg