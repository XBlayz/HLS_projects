# ==============================================================================
# DEFAULT POLICY: Ignore everything
# ==============================================================================
*

# ==============================================================================
# DIRECTORY TRAVERSAL
# ==============================================================================
# Allow Git to traverse directories to evaluate nested whitelist rules
!*/

# ==============================================================================
# ABSOLUTE BLACKLIST: Force ignore specific structures
# ==============================================================================
# Prevent traversal and tracking of build and IDE specific directories
/build/
/projects/*/_ide/
/.vscode/
/.kilo/

# ==============================================================================
# WHITELIST RULES: Allow specific files and directories
# ==============================================================================
# 1. Allow only the root .gitignore
!/.gitignore

# 2. Allow specific root directories and all their contents
!/scripts/**
!/reports/**
!/srcs/**

# 3. Allow specific source files only inside project components
# Structure targeted: /projects/<project_name>/<component_name>/
!/projects/*/*/*.hpp
!/projects/*/*/*.cpp
!/projects/*/*/*.cfg

# 4. Allow specific files
!README.md